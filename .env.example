# ──────────────────────────────────────────────────────────────────────────────
# JobNest V2 — Environment Configuration Template
#
# Copy this file to `.env.local` for local development.
# Never commit real secrets. Use a secrets manager in production.
#
# Required vars are marked with [REQUIRED].
# Optional vars are marked with [OPTIONAL] and have defaults where applicable.
# ──────────────────────────────────────────────────────────────────────────────


# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development


# ── Supabase ──────────────────────────────────────────────────────────────────
# [REQUIRED] Your project's Supabase URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# [REQUIRED] Supabase anonymous (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# [REQUIRED in production] Supabase service role key — NEVER expose client-side
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# [OPTIONAL] Database direct connection (for migrations / pgbouncer)
DATABASE_URL=postgresql://postgres:password@db.YOUR_PROJECT_ID.supabase.co:5432/postgres


# ── Application ───────────────────────────────────────────────────────────────
# [OPTIONAL] Public app URL (used for OG images, emails, OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [OPTIONAL] Internal API base URL (if different from app URL)
NEXT_PUBLIC_API_URL=http://localhost:3000


# ── AI Intelligence Platform ──────────────────────────────────────────────────
# [OPTIONAL] Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key

# [OPTIONAL] OpenAI API key (fallback provider)
OPENAI_API_KEY=your-openai-api-key

# [OPTIONAL] AI provider preference: gemini | openai | mock
AI_PROVIDER=gemini


# ── Financial Platform (Razorpay) ─────────────────────────────────────────────
# [OPTIONAL] Razorpay integration keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your-razorpay-secret

# [OPTIONAL] Webhook secret for Razorpay payment events
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret


# ── Storage ───────────────────────────────────────────────────────────────────
# [OPTIONAL] Supabase storage bucket names
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_AVATARS=avatars
STORAGE_BUCKET_MEDIA=media


# ── Cache (Upstash Redis) ─────────────────────────────────────────────────────
# [OPTIONAL] Upstash Redis REST credentials — if absent, in-memory LRU is used
UPSTASH_REDIS_REST_URL=https://YOUR_REGION.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token


# ── Geospatial ────────────────────────────────────────────────────────────────
# [OPTIONAL] Map tile provider (defaults to OpenStreetMap)
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# [OPTIONAL] Google Maps / Mapbox token if used
NEXT_PUBLIC_MAPS_API_KEY=


# ── Realtime ──────────────────────────────────────────────────────────────────
# Supabase Realtime is enabled via Supabase keys above.
# [OPTIONAL] Toggle realtime features (true by default)
NEXT_PUBLIC_FEATURE_REALTIME=true


# ── Feature Flags ─────────────────────────────────────────────────────────────
# [OPTIONAL] Enable AI-powered job matching
NEXT_PUBLIC_FEATURE_AI_MATCHING=true

# [OPTIONAL] Enable trust & safety verification features
NEXT_PUBLIC_FEATURE_TRUST_SAFETY=true

# [OPTIONAL] Enable financial / wallet features
NEXT_PUBLIC_FEATURE_FINANCE=true


# ── Observability ─────────────────────────────────────────────────────────────
# [OPTIONAL] Log level: debug | info | warn | error
LOG_LEVEL=info

# [REQUIRED in production] Secret token for /api/metrics endpoint access
METRICS_SECRET=your-metrics-secret-min-32-chars

# [OPTIONAL] OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# [OPTIONAL] Service name for traces
OTEL_SERVICE_NAME=jobnest-api


# ── Email (Supabase Auth emails are built-in) ─────────────────────────────────
# [OPTIONAL] Custom SMTP for transactional emails (uses Supabase built-in if absent)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@jobnest.in


# ── Security ──────────────────────────────────────────────────────────────────
# [OPTIONAL] CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# [OPTIONAL] Rate limit — max requests per minute per IP on API routes
RATE_LIMIT_API_RPM=60
