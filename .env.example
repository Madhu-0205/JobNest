# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (PostgreSQL - Later Phase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobnest

# Supabase Credentials (Later Phase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Payments (Razorpay - Later Phase)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Ollama AI Configuration (Later Phase)
OLLAMA_API_URL=http://localhost:11434

# Security Secrets
NEXTAUTH_SECRET=your-nextauth-secret-key-32-chars
